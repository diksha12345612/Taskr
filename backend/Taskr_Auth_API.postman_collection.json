                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"not-an-email\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\"\n}"
                        },
                        "url": {
