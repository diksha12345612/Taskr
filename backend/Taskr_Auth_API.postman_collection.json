                            "type": "text"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "register"]
                        }
                    }
                },
