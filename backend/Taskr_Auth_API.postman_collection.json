                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "register"]
                        }
                    }
                },
                {
                    "name": "Login - Invalid Credentials",
                    "request": {
                        "method": "POST",
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json",
                            "type": "text"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"wrongpassword\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "login"]
                        }
                    }
                },
                {
                    "name": "Login - User Not Found",
                    "request": {
                        "method": "POST",
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json",
                            "type": "text"
                        }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"nonexistent@example.com\",\n  \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "login"]
                        }
                    }
                },
                {
                    "name": "Get Profile - No Token",
                    "request": {
                        "method": "GET",
                        "header": [{
                            "key": "Content-Type",
                            "value": "application/json",
                            "type": "text"
                        }],
                        "url": {
                            "raw": "{{base_url}}/api/auth/profile",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "profile"]
                        }
                    }
                },
                {
                    "name": "Get Profile - Invalid Token",
                    "request": {
                        "method": "GET",
                        "header": [{
                                "key": "Authorization",
                                "value": "Bearer invalid.token.here",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/auth/profile",
                            "host": ["{{base_url}}"],
                            "path": ["api", "auth", "profile"]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [{
            "key": "base_url",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "user_id",
            "value": "",
