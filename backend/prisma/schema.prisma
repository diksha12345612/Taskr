// Prisma Schema for Taskr - Team Task Manager
// Generated: May 2026
// Database: SQLite (Changed for maximum compatibility)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODELS - Database tables with relationships
// ============================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password             String
  role                 String    @default("Member") // Admin, Member
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  assignedTasks Task[] @relation("assignee")
  projects      Project[] @relation("ProjectMembers")
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  
  createdAt DateTime @default(now())

  @@index([email])
  @@index([role])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      String @default("Active") // Active, Review, Hold
  progress    Int           @default(0)
  
  tasks   Task[]
  members User[] @relation("ProjectMembers")
  
  createdAt DateTime @default(now())

  @@index([status])
  @@index([progress])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    String @default("Medium") // High, Medium, Low
  status      String   @default("Todo") // Todo, InProgress, Completed
  dueDate     DateTime?
  
  projectId  String
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId String?
  assignee   User?        @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String @default("Present") // Present, Absent, Late
  checkIn   DateTime?
  checkOut  DateTime?
  
  @@unique([userId, date])
}

model LeaveRequest {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String      
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String @default("Pending") // Pending, Approved, Rejected
  
  createdAt  DateTime    @default(now())
}
