// Prisma Schema for Taskr - Team Task Manager
// Generated: May 2026
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS - Type-safe status and role definitions
// ============================================================================

enum UserRole {
  Admin   
  Member  
}

enum ProjectStatus {
  Active      
  Review      
  Hold        
}

enum TaskStatus {
  Todo        
  InProgress  
  Completed   
}

enum TaskPriority {
  High        
  Medium      
  Low         
}

enum AttendanceStatus {
  Present
  Absent
  Late
}

enum LeaveStatus {
  Pending
  Approved
  Rejected
}

// ============================================================================
// MODELS - Database tables with relationships
// ============================================================================

model User {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.Text
  role      UserRole @default(Member)
  
  assignedTasks Task[] @relation("assignee")
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  
  createdAt DateTime @default(now())

  @@index([email])
  @@index([role])
  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProjectStatus @default(Active)
  progress    Int           @default(0) @db.SmallInt 
  
  tasks Task[]
  
  createdAt DateTime @default(now())

  @@index([status])
  @@index([progress])
  @@map("projects")
}

model Task {
  id          String       @id @default(cuid())
  title       String       @db.VarChar(255)
  description String?      @db.Text
  priority    TaskPriority @default(Medium)
  status      TaskStatus   @default(Todo)
  dueDate     DateTime?    @db.Date
  
  projectId  String
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId String?
  assignee   User?        @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("tasks")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus @default(Present)
  checkIn   DateTime?
  checkOut  DateTime?
  
  @@unique([userId, date])
  @@map("attendance")
}

model LeaveRequest {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String      
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  reason     String?     @db.Text
  status     LeaveStatus @default(Pending)
  
  createdAt  DateTime    @default(now())
  @@map("leave_requests")
}
