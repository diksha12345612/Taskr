# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# Local Development: SQLite
DATABASE_URL="file:./dev.db"

# For Production Deployment:
# Set DATABASE_URL as environment variable in your deployment platform (Railway, Heroku, etc.)
# Examples:
# SQLite: DATABASE_URL="file:./dev.db"
# PostgreSQL: DATABASE_URL="postgresql://user:password@host:port/database"

# JWT Configuration
# Use a strong secret key (min 32 characters) in production
JWT_SECRET=TaskrSuperSecretKey2026_VerySecureKey123eKey123
JWT_EXPIRE=7d

# CORS Configuration
# Local: http://localhost:5173
# Production: Set your frontend URL
CORS_ORIGIN=http://localhost:5173

# API Configuration
API_PREFIX=/api

# Optional: Logging
LOG_LEVEL=info
